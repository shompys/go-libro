---
import { getCollection } from 'astro:content';

const entries = await getCollection('docs');
const sections: Record<string, any[]> = {};

for (const e of entries.sort((a, b) => {
  const aOrder = a.id === 'indice' ? 0 : a.id.startsWith('estandard/') ? 1 : 2;
  const bOrder = b.id === 'indice' ? 0 : b.id.startsWith('estandard/') ? 1 : 2;
  return aOrder - bOrder || a.id.localeCompare(b.id);
})) {
  if (e.id === 'indice') continue;
  const section = e.id.split('/')[0];
  if (!sections[section]) sections[section] = [];
  sections[section]!.push(e);
}
---

<nav class="sidebar">
  <a class="home-link" href="/indice">&larr; Índice general</a>
  
  {Object.entries(sections).map(([section, items]) => (
    <details class="section" open>
      <summary>{section === 'estandard' ? '📦 Estándar' : '📦 No Estándar'}</summary>
      <ul>
        {items.map(item => (
          <li>
            <a href={`/${item.id}`} class:list={{ active: Astro.url?.pathname === `/${item.id}` }}>
              {item.id.split('/').slice(1).join(' / ')}
            </a>
          </li>
        ))}
      </ul>
    </details>
  ))}
</nav>

<style>
  .sidebar {
    width: 280px;
    min-width: 280px;
    height: 100vh;
    overflow-y: auto;
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 1rem;
    font-size: 0.85rem;
    position: sticky;
    top: 0;
    border-right: 1px solid #333;
  }
  .home-link {
    display: block;
    padding: 0.5rem;
    color: #7ec8e3;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 0.5rem;
    border-radius: 4px;
  }
  .home-link:hover { background: #16213e; }
  .section {
    margin-bottom: 0.5rem;
  }
  .section summary {
    cursor: pointer;
    padding: 0.4rem 0.5rem;
    font-weight: 600;
    color: #f0f0f0;
    border-radius: 4px;
  }
  .section summary:hover { background: #16213e; }
  .section ul {
    list-style: none;
    padding-left: 0.5rem;
    margin: 0.25rem 0;
  }
  .section li a {
    display: block;
    padding: 0.25rem 0.5rem;
    color: #b0b0b0;
    text-decoration: none;
    border-radius: 3px;
    font-size: 0.8rem;
  }
  .section li a:hover { background: #16213e; color: #fff; }
  .section li a.active { background: #0f3460; color: #7ec8e3; }

  @media (max-width: 768px) {
    .sidebar { display: none; }
  }
</style>
